# ─────────────────────────────────────────────────────────────────────────────
# Threat Feed Service — variables de entorno
# Copia este fichero a .env y rellena los valores antes de levantar el servicio.
#
#   cp .env.example .env
#
# Generar API_KEY aleatoria (elige uno):
#   Linux/macOS:  openssl rand -hex 32
#   PowerShell:   -join ((1..32) | ForEach { '{0:x}' -f (Get-Random -Max 256) })
#   Python:       python3 -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────────


# ── Requerida ─────────────────────────────────────────────────────────────────

# Clave de acceso a los endpoints protegidos (X-API-Key).
# Mínimo 32 caracteres. Generar con: openssl rand -hex 32
API_KEY=


# ── Comportamiento de promoción ───────────────────────────────────────────────

# Número de ocurrencias para promover un temporal a permanente.
# Default: 5
THRESHOLD_PROMOTION=5

# Activar/desactivar la promoción automática (true | false).
# false = se sigue contando el historial, pero nunca se promueve solo.
# Default: true
PROMOTION_ENABLED=true


# ── Opcionales ────────────────────────────────────────────────────────────────

# Habilita Swagger UI en /docs y /openapi.json.
# Mantener en false en producción.
# Default: false
DEBUG=false

# Ruta interna del fichero SQLite dentro del contenedor.
# No cambiar salvo que también se modifique el volumen en docker-compose.yml.
# Default: /data/threatfeed.db
# DB_PATH=/data/threatfeed.db


# ── Seed inicial ─────────────────────────────────────────────────────────────

# Cargar las listas de IPs y dominios al arrancar (true | false).
# Los ficheros se leen desde build/seeds/ — están dentro de la imagen.
# INSERT OR IGNORE: los elementos ya existentes no se tocan.
# Default: true
SEED_ENABLED=true


# ── Variables custom ──────────────────────────────────────────────────────────
# Añade aquí cualquier variable extra que referencíes en docker-compose.yml.
# MY_VAR=valor
