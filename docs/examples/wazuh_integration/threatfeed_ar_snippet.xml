<!--
  =============================================================================
  Threat Feed Service — Integración Wazuh Active Response
  =============================================================================
  Añadir este bloque al ossec.conf del MANAGER (dentro de <ossec_config>).
  Los scripts deben estar en /var/ossec/active-response/bin/ en el manager.

  FLUJO COMPLETO:
    1. Wazuh detecta ataque → AR bloquea en el agente (netsh/iptables)
    2. threatfeed-add-ip.sh → envía srcip al Threat Feed (temporary 1-24h)
    3. Threat Feed acumula ocurrencias → promueve a permanent si supera umbral
    4. sync_ips_atacantes.sh (cron cada 5 min):
         GET /feed/ip/active → ips_atacantes CDB → Wazuh API compila lista
    5. Regla 100202: próxima petición de esa IP → match en ips_atacantes
         → AR firewall-drop 24h automático sin esperar a que dispare otra regla

  CONFIGURACION — /var/ossec/etc/threatfeed.conf:
    THREATFEED_HOST="http://<host>:8000"
    THREATFEED_API_KEY="<clave>"
    THREATFEED_DEDUP_WINDOW="300"
    WAZUH_API_HOST="https://localhost:55000"
    WAZUH_API_USER="wazuh-wui"          # o cualquier usuario con permiso lists:update
    WAZUH_API_PASS="<password>"

  DESPLIEGUE:
    cp threatfeed-add-ip.sh     /var/ossec/active-response/bin/
    cp threatfeed-add-domain.sh /var/ossec/active-response/bin/
    cp sync_ips_atacantes.sh    /var/ossec/active-response/bin/
    chmod 750  /var/ossec/active-response/bin/threatfeed-add-ip.sh
    chmod 750  /var/ossec/active-response/bin/threatfeed-add-domain.sh
    chmod 750  /var/ossec/active-response/bin/sync_ips_atacantes.sh
    chown root:wazuh /var/ossec/active-response/bin/threatfeed-add-ip.sh
    chown root:wazuh /var/ossec/active-response/bin/threatfeed-add-domain.sh
    chown root:wazuh /var/ossec/active-response/bin/sync_ips_atacantes.sh
    chmod 640  /var/ossec/etc/threatfeed.conf
    chown root:wazuh /var/ossec/etc/threatfeed.conf

  CRON en el HOST — /etc/cron.d/threatfeed-sync:
    # Actualiza ips_atacantes CDB y recarga Wazuh cada noche a las 3am
    0 3 * * * root docker exec wazuh-manager \
        /var/ossec/active-response/bin/sync_ips_atacantes.sh

  threatfeed.conf (sin credenciales):
    THREATFEED_HOST="http://<nombre-servicio-docker>:8000"   # ej. http://threatfeed:8000
    THREATFEED_API_KEY="<clave>"
    THREATFEED_DEDUP_WINDOW="300"
  =============================================================================
-->

<ossec_config>

  <!-- ── Comandos Threat Feed ──────────────────────────────────────────────── -->

  <!-- Bloqueo de IP: envía srcip al Threat Feed como temporary -->
  <command>
    <name>threatfeed-add-ip</name>
    <executable>threatfeed-add-ip.sh</executable>
    <timeout_allowed>no</timeout_allowed>
  </command>

  <!-- Bloqueo de dominio: envía el dominio al Threat Feed como permanent -->
  <command>
    <name>threatfeed-add-domain</name>
    <executable>threatfeed-add-domain.sh</executable>
    <timeout_allowed>no</timeout_allowed>
  </command>

  <!-- ── Active Response — IPs ─────────────────────────────────────────────── -->
  <!--
    Se dispara en el MANAGER cuando cualquier regla del grupo ar_block se activa.
    Corre en paralelo con el AR que bloquea en el agente (netsh, block-ip-inbound…).
    timeout_allowed:no porque el TTL lo gestiona el Threat Feed de forma nativa.
  -->
  <active-response>
    <disabled>no</disabled>
    <command>threatfeed-add-ip</command>
    <location>server</location>
    <rules_group>ar_block</rules_group>
  </active-response>

  <!-- ── Active Response — Dominios ───────────────────────────────────────── -->
  <!--
    Se dispara cuando una regla del grupo ar_block_domain se activa.
    Los dominios se añaden como permanent (igual que el AR original sin timeout).
  -->
  <active-response>
    <disabled>no</disabled>
    <command>threatfeed-add-domain</command>
    <location>server</location>
    <rules_group>ar_block_domain</rules_group>
  </active-response>

</ossec_config>
